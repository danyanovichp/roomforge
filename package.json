{
    "name": "roomforge",
    "version": "0.1.0",
    "description": "Browser-based interior planning demo with 2D and isometric review.",
    "type": "module",
    "bin": {
        "roomforge": "./scripts/serve.mjs"
    },
    "files": [
        "dist",
        "scripts/serve.mjs",
        "scripts/start.mjs",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "start": "node ./scripts/start.mjs",
        "setup": "npm install",
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "prepack": "npm run build",
        "verify:package": "node ./scripts/smoke-package.mjs"
    },
    "keywords": [
        "roomforge",
        "interior-design",
        "planner",
        "3d",
        "vite"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@react-three/drei": "^9.50.0",
        "@react-three/fiber": "^8.12.0",
        "framer-motion": "^10.12.0",
        "lucide-react": "^0.220.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "three": "^0.150.1"
    },
    "devDependencies": {
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.11",
        "@vitejs/plugin-react": "^3.1.0",
        "vite": "^4.2.0"
    }
}
